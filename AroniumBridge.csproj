<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>14</LangVersion>
    <RootNamespace>AroniumBridge</RootNamespace>
    <AssemblyName>AroniumBridge</AssemblyName>
    <Version>1.0.0</Version>
    <Optimize>true</Optimize>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>$(NoWarn);CA1416</NoWarn>
    <RuntimeIdentifiers>win-x64;win-x86</RuntimeIdentifiers>
    <ApplicationIcon>app.ico</ApplicationIcon>
  </PropertyGroup>

  <!--
    PRE-BUILD: Write app.ico from embedded Base64.
    Uses only PowerShell + .NET Convert — no System.Drawing, no scripts to run manually.
    Skips regeneration if the file already exists (fast no-op on subsequent builds).
  -->
  <PropertyGroup>
    <AppIconBase64></AppIconBase64>
  </PropertyGroup>

  <Target Name="EnsureAppIcon" BeforeTargets="BeforeBuild;CoreCompile">
    <PropertyGroup>
      <_AppIcoPath>$(MSBuildProjectDirectory)\app.ico</_AppIcoPath>
    </PropertyGroup>
    <!-- Only write if missing — fast no-op on subsequent builds -->
    <Exec Condition="!Exists('$(_AppIcoPath)')" Command="powershell.exe -NoProfile -NonInteractive -Command &quot;[System.IO.File]::WriteAllBytes('$(_AppIcoPath)', [System.Convert]::FromBase64String('$(AppIconBase64)'))&quot;" ConsoleToMSBuild="true" />
    <Message Text="app.ico ready." Importance="normal" />
  </Target>

  <ItemGroup>
    <Content Include="app.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.IO.Ports" Version="10.0.5" />
  </ItemGroup>

</Project>
