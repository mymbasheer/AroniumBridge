<Window x:Class="AroniumBridge.UI.DisplaySimulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDLED8 Display Simulator"
        Width="700"
        Height="580"
        MinWidth="520"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Background="#1A1A2E"
        FontFamily="Segoe UI">

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo Description="PDLED8 Display Simulator"/>
    </Window.TaskbarItemInfo>

    <Window.Resources>

        <Style x:Key="PanelHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"   Value="10.5"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>

        <Style x:Key="TestInput" TargetType="TextBox">
            <Setter Property="FontFamily"               Value="Consolas"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="Foreground"               Value="#E2E8F0"/>
            <Setter Property="Background"               Value="#0F0F1E"/>
            <Setter Property="BorderBrush"              Value="#374151"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="36"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"               Value="#F59E0B"/>
            <Setter Property="SelectionBrush"           Value="#F59E0B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#F59E0B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeButton" TargetType="RadioButton">
            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Foreground"      Value="#6B7280"/>
            <Setter Property="Background"      Value="#0F0F1E"/>
            <Setter Property="BorderBrush"     Value="#1F2937"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#161628"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#1A1A2E"/>
            <Setter Property="Background"      Value="#F59E0B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="18,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D97706"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B45309"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Foreground"      Value="#4B5563"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0  Title + pill -->
            <RowDefinition Height="14"/>     <!-- 1  Gap -->
            <RowDefinition Height="Auto"/>   <!-- 2  Display housing -->
            <RowDefinition Height="14"/>     <!-- 3  Gap -->
            <RowDefinition Height="Auto"/>   <!-- 4  Last update -->
            <RowDefinition Height="14"/>     <!-- 5  Gap -->
            <RowDefinition Height="Auto"/>   <!-- 6  Manual test panel -->
            <RowDefinition Height="14"/>     <!-- 7  Gap -->
            <RowDefinition Height="*"/>      <!-- 8  Log -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════
             ROW 0  TITLE + LIVE PILL
        ═══════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="PDLED8 Display Simulator"
                           FontFamily="Segoe UI Semibold"
                           FontSize="15"
                           Foreground="#E2E8F0"/>
                <TextBlock Text="8-digit display  ·  ESC/POS (CLR → ESC s n → ESC l n → ESC Q A … CR)"
                           FontSize="11"
                           Foreground="#4B5563"
                           Margin="0,3,0,0"/>
            </StackPanel>
            <Border Grid.Column="1"
                    x:Name="LivePill"
                    Background="#064E3B"
                    CornerRadius="10"
                    Padding="10,4"
                    VerticalAlignment="Center">
                <TextBlock x:Name="TxtLiveStatus"
                           Text="● LIVE"
                           FontFamily="Segoe UI Semibold"
                           FontSize="11"
                           Foreground="#34D399"/>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════
             ROW 2  DISPLAY HOUSING
             Accurately mirrors the physical PDLED8:
               • Top: 8 amber 7-segment digit cells
               • Bottom: 4 hardware indicator label lights
        ═══════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#080812"
                CornerRadius="10"
                Padding="20,16,20,14">
            <Border.Effect>
                <DropShadowEffect Color="#F59E0B" BlurRadius="24"
                                  ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>

            <StackPanel>

                <!-- Brand strip -->
                <Border Background="#0D0D20"
                        CornerRadius="3"
                        Padding="8,3"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,10">
                    <TextBlock Text="PDLED8  ·  8-DIGIT CUSTOMER DISPLAY  ·  RS-232  ·  ESC/POS"
                               FontFamily="Consolas"
                               FontSize="8.5"
                               Foreground="#2D3748"/>
                </Border>

                <!-- ── 8 DIGIT CELLS ───────────────────────── -->
                <Border Background="#050510"
                        CornerRadius="6"
                        Padding="12,10">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="12"
                                          ShadowDepth="0" Opacity="0.9"/>
                    </Border.Effect>

                    <ItemsControl x:Name="DigitPanel">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!--
                                    Each cell = one digit position (uniform 40×60).
                                    The digit character renders at full 36 pt.
                                    The decimal point is a separate small glowing
                                    Ellipse in the bottom-right corner, shown only
                                    when HasDot = true — exactly like a real
                                    7-segment display.  This keeps all digit cells
                                    visually identical regardless of decimal point.
                                -->
                                <Grid Width="40" Height="60" Margin="2,0">

                                    <!-- Cell background -->
                                    <Border Background="#07071A"
                                            BorderBrush="#0E0E25"
                                            BorderThickness="1"
                                            CornerRadius="3"/>

                                    <!-- Digit at full size, always centred -->
                                    <TextBlock Text="{Binding Char}"
                                               FontFamily="Consolas"
                                               FontSize="36"
                                               FontWeight="Bold"
                                               Foreground="#F59E0B"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#F59E0B"
                                                              BlurRadius="8"
                                                              ShadowDepth="0"
                                                              Opacity="0.65"/>
                                        </TextBlock.Effect>
                                    </TextBlock>

                                    <!-- Decimal point dot (bottom-right corner) -->
                                    <Ellipse Width="7" Height="7"
                                             Fill="#F59E0B"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Bottom"
                                             Margin="0,0,2,4"
                                             Visibility="{Binding DotVisibility}">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#F59E0B"
                                                              BlurRadius="7"
                                                              ShadowDepth="0"
                                                              Opacity="0.9"/>
                                        </Ellipse.Effect>
                                    </Ellipse>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- ── HARDWARE INDICATOR LABELS ──────────────
                     These represent the physical silk-screened /
                     LED indicator labels at the bottom of the
                     PDLED8 PCB, controlled by ESC s n.
                ─────────────────────────────────────────────── -->
                <Border Margin="0,8,0,0"
                        Background="#060612"
                        CornerRadius="4"
                        Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- PRICE indicator -->
                        <StackPanel Grid.Column="0"
                                    HorizontalAlignment="Center">
                            <Border x:Name="IndicatorPrice"
                                    Width="8" Height="8"
                                    CornerRadius="4"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,3">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BrushPrice" Color="#1F2937"/>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="LblPrice"
                                       Text="PRICE"
                                       FontFamily="Consolas"
                                       FontSize="9"
                                       Foreground="#374151"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- TOTAL indicator -->
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center">
                            <Border x:Name="IndicatorTotal"
                                    Width="8" Height="8"
                                    CornerRadius="4"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,3">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BrushTotal" Color="#1F2937"/>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="LblTotal"
                                       Text="TOTAL"
                                       FontFamily="Consolas"
                                       FontSize="9"
                                       Foreground="#374151"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- COLLECT indicator -->
                        <StackPanel Grid.Column="2"
                                    HorizontalAlignment="Center">
                            <Border x:Name="IndicatorCollect"
                                    Width="8" Height="8"
                                    CornerRadius="4"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,3">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BrushCollect" Color="#1F2937"/>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="LblCollect"
                                       Text="COLLECT"
                                       FontFamily="Consolas"
                                       FontSize="9"
                                       Foreground="#374151"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- CHANGE indicator -->
                        <StackPanel Grid.Column="3"
                                    HorizontalAlignment="Center">
                            <Border x:Name="IndicatorChange"
                                    Width="8" Height="8"
                                    CornerRadius="4"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,3">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BrushChange" Color="#1F2937"/>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="LblChange"
                                       Text="CHANGE"
                                       FontFamily="Consolas"
                                       FontSize="9"
                                       Foreground="#374151"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════
             ROW 4  LAST UPDATE
        ═══════════════════════════════ -->
        <TextBlock x:Name="TxtLastUpdate"
                   Grid.Row="4"
                   Text="Waiting for first transaction…"
                   FontSize="11.5"
                   Foreground="#4B5563"
                   HorizontalAlignment="Center"/>

        <!-- ═══════════════════════════════
             ROW 6  MANUAL TEST PANEL
        ═══════════════════════════════ -->
        <Border Grid.Row="6"
                Background="#0D0D1F"
                BorderBrush="#1F2937"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="MANUAL TEST"
                           Style="{StaticResource PanelHeader}"
                           Margin="0"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <RadioButton x:Name="RbPrice"   Grid.Column="0" Content="PRICE"
                                 Style="{StaticResource ModeButton}" Margin="0,0,4,0"
                                 Checked="ModeButton_Checked"/>
                    <RadioButton x:Name="RbTotal"   Grid.Column="1" Content="TOTAL"
                                 Style="{StaticResource ModeButton}" IsChecked="True"
                                 Margin="0,0,4,0" Checked="ModeButton_Checked"/>
                    <RadioButton x:Name="RbCollect" Grid.Column="2" Content="COLLECT"
                                 Style="{StaticResource ModeButton}" Margin="0,0,4,0"
                                 Checked="ModeButton_Checked"/>
                    <RadioButton x:Name="RbChange"  Grid.Column="3" Content="CHANGE"
                                 Style="{StaticResource ModeButton}"
                                 Checked="ModeButton_Checked"/>

                    <TextBox x:Name="TxtTestAmount"
                             Grid.Column="5"
                             Style="{StaticResource TestInput}"
                             ToolTip="Enter an amount (e.g. 1250.75) and press Send or Enter."
                             PreviewTextInput="TxtTestAmount_PreviewTextInput"
                             KeyDown="TxtTestAmount_KeyDown"/>

                    <Button x:Name="BtnSend"
                            Grid.Column="7"
                            Content="▶  Send"
                            Style="{StaticResource SendButton}"
                            Click="BtnSend_Click"/>

                    <Button x:Name="BtnClear"
                            Grid.Column="9"
                            Content="Clear Log"
                            Style="{StaticResource GhostButton}"
                            Click="BtnClear_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════
             ROW 8  RECEIVE LOG
        ═══════════════════════════════ -->
        <Border Grid.Row="8"
                Background="#0D0D1F"
                BorderBrush="#1F2937"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="RECEIVE LOG"
                           Style="{StaticResource PanelHeader}"/>
                <ScrollViewer Grid.Row="1"
                              x:Name="LogScroller"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="LogPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
