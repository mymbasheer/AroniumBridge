<Window x:Class="AroniumBridge.UI.DiagnosticDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AroniumBridge.UI"
        Title="Aronium Bridge - System Check" Height="500" Width="600"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F7FA" FontFamily="Segoe UI">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="System Diagnostics" FontSize="24" FontWeight="SemiBold" Foreground="#2D3748"/>
            <TextBlock Text="Checking com0com and hardware configuration..." FontSize="14" Foreground="#718096" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White">
            <ItemsControl x:Name="ResultsList" Margin="10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="10,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Path x:Name="StatusIcon" Width="20" Height="20" Margin="0,2,15,0" Stretch="Uniform" VerticalAlignment="Top">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Ok">
                                                    <Setter Property="Data" Value="M10,20A10,10 0 0,1 0,10A10,10 0 0,1 10,0A10,10 0 0,1 20,10A10,10 0 0,1 10,20M8.66,14.33L5,10.66L6.33,9.33L8.66,11.66L13.66,6.66L15,8L8.66,14.33Z"/>
                                                    <Setter Property="Fill" Value="#48BB78"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                    <Setter Property="Data" Value="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z"/>
                                                    <Setter Property="Fill" Value="#ECC94B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                                    <Setter Property="Data" Value="M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2M15.59,17L12,13.41L8.41,17L7,15.59L10.59,12L7,8.41L8.41,7L12,10.59L15.59,7L17,8.41L13.41,12L17,15.59L15.59,17Z"/>
                                                    <Setter Property="Fill" Value="#F56565"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Message}" FontWeight="Medium" FontSize="15" Foreground="#2D3748"/>
                                    <TextBlock Text="{Binding Details}" FontSize="12" Foreground="#718096" TextWrapping="Wrap" Margin="0,4,0,0" 
                                               Visibility="{Binding Details, Converter={local:StringNullOrEmptyToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SecondaryBtn" Content="Install com0com" Margin="0,0,12,0" Padding="20,8" 
                    Background="White" BorderBrush="#CBD5E0" BorderThickness="1" Foreground="#4A5568"
                    Visibility="Collapsed" Click="SecondaryBtn_Click"/>
            <Button x:Name="PrimaryBtn" Content="Close" Padding="25,8" 
                    Background="#3182CE" BorderThickness="0" Foreground="White" FontWeight="SemiBold"
                    Click="PrimaryBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
